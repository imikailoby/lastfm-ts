{
    "name": "@imikailoby/lastfm-ts",
    "version": "2.0.1",
    "description": "A minimalistic TypeScript-based client for Last.fm API 2.0",
    "author": "Mikhail Prosmitskiy",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/imikailoby/lastfm-ts.git"
    },
    "main": "dist/index.min.js",
    "types": "dist/index.min.d.js",
    "scripts": {
        "build": "rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
        "lint": "eslint src/",
        "test": "jest",
        "format": "prettier . --write --log-level warn"
    },
    "keywords": [
        "lastfm",
        "typescript",
        "api"
    ],
    "license": "MIT",
    "devDependencies": {
        "@rollup/plugin-terser": "^0.4.4",
        "@rollup/plugin-typescript": "^12.3.0",
        "@types/jest": "^29.5.12",
        "@types/node": "^20.11.24",
        "eslint": "^9.0.0",
        "jest": "^29.7.0",
        "prettier": "^3.8.0",
        "rollup": "^4.60.0",
        "rollup-plugin-dts": "^6.4.1",
        "ts-jest": "^29.4.0",
        "ts-node": "^10.9.2",
        "tslib": "^2.8.1",
        "typescript": "^5.8.0",
        "typescript-eslint": "^8.0.0"
    },
    "packageManager": "yarn@4.1.0",
    "engines": {
        "node": ">=20.11.1"
    }
}
